{
  "name": "@pedrofariasx/qwenproxy",
  "version": "1.12.7",
  "description": "Local OpenAI-compatible proxy API that routes requests to Qwen (chat.qwen.ai) via Playwright browser automation.",
  "scripts": {
    "start": "node node_modules/tsx/dist/cli.mjs src/index.ts",
    "start:simple": "node node_modules/tsx/dist/cli.mjs src/index.ts",
    "login": "node node_modules/tsx/dist/cli.mjs src/login.ts",
    "test": "node node_modules/tsx/dist/cli.mjs --test src/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "import-cookies": "bash import-cookies.sh"
  },
  "keywords": [
    "openai",
    "proxy",
    "qwen",
    "playwright",
    "llm",
    "api",
    "chat-completions"
  ],
  "author": "Pedro Farias",
  "license": "ISC",
  "dependencies": {
    "@hono/node-server": "^2.0.3",
    "ajv": "^8.20.0",
    "ali-oss": "^6.23.0",
    "better-sqlite3": "^12.10.1",
    "dotenv": "^17.4.2",
    "hono": "^4.12.21",
    "tsx": "^4.22.3",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@types/ajv": "^0.0.5",
    "@types/ali-oss": "^6.23.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "eslint": "^10.5.0",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "bin": {
    "qwenproxy": "./bin/qwenproxy.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src/**/*",
    "bin/**/*"
  ],
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  }
}
